# https://editorconfig.org
root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 2

[*.md]
trim_trailing_whitespace = false

[*.{mp4,webm,mov,webp,png,jpg,jpeg,svg,woff,woff2}]
trim_trailing_whitespace = false
insert_final_newline = false
